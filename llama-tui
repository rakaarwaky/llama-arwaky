#!/usr/bin/env python3
"""
llama-tui — Simple GGUF model picker + llama-server launcher
★(◕‿◕)ノ  with per-model config support
"""

import os
import sys
import subprocess
import yaml

# ─── Paths ──────────────────────────────────────────────
SCRIPT_DIR   = os.path.dirname(os.path.abspath(__file__))
CONFIG_DIR   = os.path.join(SCRIPT_DIR, "config")
DEFAULT_CFG  = os.path.join(CONFIG_DIR, "default.yaml")
LEGACY_CFG   = os.path.join(SCRIPT_DIR, "config.yaml")   # backward compat
LLAMA_SERVER = os.path.join(SCRIPT_DIR, "llama-b9656", "llama-server")

# ─── Model → config mapping ──────────────────────────────
# Keys are substrings matched against the model's relative path (case-insensitive)
# First match wins. Falls back to default.yaml if no match.
MODEL_CONFIG_MAP = [
    # Qwopus coder — match first (specific)
    ("qwopus",                              "qwopus-coder-9b.yaml"),
    ("jackwrong",                           "qwopus-coder-9b.yaml"),

    # MiniCPM
    ("minicpm",                             "minicpm-v4.yaml"),

    # Huihui-ai QAT abliterated (huihui-ai folder) — more specific first
    ("huihui-ai",                           "gemma4-huihui-qat-abliterated.yaml"),
    ("huihui-gemma-4-12b-it-qat",          "gemma4-huihui-qat-abliterated.yaml"),

    # Huhui (huhui folder) — abliterated Q4_K_S
    ("huhui",                               "gemma4-huhui-abliterated.yaml"),

    # lmstudio-community gemma-4 QAT
    ("lmstudio-community",                  "gemma4-lmstudio-qat.yaml"),
    ("gemma-4-12b-it-qat",                 "gemma4-lmstudio-qat.yaml"),
]

# ─── Config loader ──────────────────────────────────────
def load_default_config():
    """Load default.yaml, fallback to legacy config.yaml."""
    if os.path.exists(DEFAULT_CFG):
        with open(DEFAULT_CFG) as f:
            return yaml.safe_load(f)
    if os.path.exists(LEGACY_CFG):
        with open(LEGACY_CFG) as f:
            return yaml.safe_load(f)
    raise FileNotFoundError("No config found! Create config/default.yaml")

def load_model_config(model_rel_path):
    """
    Find the best matching config for a model path.
    Returns (config_dict, config_filename).
    """
    rel_lower = model_rel_path.lower().replace("\\", "/")

    for keyword, cfg_file in MODEL_CONFIG_MAP:
        if keyword.lower() in rel_lower:
            cfg_path = os.path.join(CONFIG_DIR, cfg_file)
            if os.path.exists(cfg_path):
                with open(cfg_path) as f:
                    return yaml.safe_load(f), cfg_file

    # Fallback to default
    return load_default_config(), "default.yaml"

# ─── Find GGUF models ───────────────────────────────────
def find_models():
    models = []
    for root, dirs, files in os.walk(SCRIPT_DIR, followlinks=True):
        # Skip hidden dirs and the config dir itself
        dirs[:] = [d for d in dirs if not d.startswith('.') and d != 'config']
        for f in sorted(files):
            if f.endswith('.gguf') and not f.startswith('mmproj'):
                path = os.path.join(root, f)
                rel  = os.path.relpath(path, SCRIPT_DIR)
                size_gb = os.path.getsize(path) / (1024**3)
                models.append((path, rel, size_gb))
    return models

# ─── Find mmproj near model ─────────────────────────────
def find_mmproj(model_path):
    model_dir = os.path.dirname(model_path)
    for f in sorted(os.listdir(model_dir)):
        if f.endswith('.gguf') and ('mmproj' in f or 'mmprj' in f):
            return os.path.join(model_dir, f)
    return None

# ─── TUI ─────────────────────────────────────────────────
def print_header():
    os.system('clear' if os.name == 'posix' else 'cls')
    print("╔══════════════════════════════════════╗")
    print("║       ★ llama-tui ★  b9656          ║")
    print("║    GGUF Model Picker + Server        ║")
    print("╚══════════════════════════════════════╝")
    print(f"  📁 {SCRIPT_DIR}\n")

def show_menu(models):
    print(f"  {'#':<3} {'Model':<52} {'Size':>8}  {'Config'}")
    print(f"  {'─'*3} {'─'*52} {'─'*8}  {'─'*28}")
    for i, (path, rel, size) in enumerate(models, 1):
        _, cfg_file = load_model_config(rel)
        name = rel[:52]
        cfg_label = cfg_file.replace(".yaml", "")
        print(f"  {i:<3} {name:<52} {size:>6.1f}GB  {cfg_label}")
    print(f"  {'─'*3} {'─'*52} {'─'*8}  {'─'*28}")
    print(f"\n  {len(models)+1}. ❌  Exit\n")

def get_choice(max_choice):
    while True:
        try:
            choice = input("  🔢 Pilih nomor [1-{}]: ".format(max_choice)).strip()
            if not choice:
                continue
            n = int(choice)
            if 1 <= n <= max_choice:
                return n
        except ValueError:
            pass
        print(f"  ⚠️  Masukin angka 1-{max_choice} ya~!")

# ─── Clickable URL (OSC 8 terminal hyperlink) ──────────
def link(url, text=None):
    """Return a clickable OSC 8 hyperlink for terminals that support it."""
    text = text or url
    return f"\033]8;;{url}\033\\{text}\033]8;;\033\\"

def print_ready_banner(host, port):
    url_chat    = f"http://{host}:{port}"
    url_api     = f"http://{host}:{port}/v1/chat/completions"
    url_metrics = f"http://{host}:{port}/metrics"
    print()
    print(f"  ╔══ ✅ Server Ready ══════════════════════╗")
    print(f"  ║  {link(url_chat,    '🌐 Open in Browser      → ' + url_chat):<}")
    print(f"  ║  {link(url_api,     '🔗 API endpoint         → ' + url_api):<}")
    print(f"  ║  {link(url_metrics, '📡 Metrics              → ' + url_metrics):<}")
    print(f"  ╚════════════════════════════════════════╝")
    print()
    sys.stdout.flush()
    # Auto-open browser (fire-and-forget, ignore errors)
    try:
        subprocess.Popen(
            ["xdg-open", url_chat],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except Exception:
        pass

# ─── Launch server ──────────────────────────────────────
def launch_server(cfg, model_path, cfg_name="default.yaml"):
    scfg = cfg['server']

    # Build args
    args = [
        LLAMA_SERVER,
        "-m", model_path,
        "--host", scfg['host'],
        "--port", str(scfg['port']),
        "-ngl", str(scfg['ngl']),
        "-c", str(scfg['ctx']),
        "-t", str(scfg['threads']),
        "--threads-batch", str(scfg['threads_batch']),
        "--temp", str(scfg['temp']),
        "--top-k", str(scfg['top_k']),
        "--top-p", str(scfg['top_p']),
    ]

    if scfg.get('flash_attn'):
        args += ["--flash-attn", "on"]
    if scfg.get('no_kv_offload'):
        args.append("--no-kv-offload")
    if scfg.get('cache_type_k'):
        args += ["--cache-type-k", scfg['cache_type_k']]
    if scfg.get('cache_type_v'):
        args += ["--cache-type-v", scfg['cache_type_v']]
    if scfg.get('reasoning_budget') is not None:
        args += ["--reasoning-budget", str(scfg['reasoning_budget'])]

    # Auto mmproj
    mmproj = find_mmproj(model_path)
    mcfg   = cfg.get('multimodal', {})
    if mmproj and mcfg.get('mmproj') == 'auto':
        args += ["--mmproj", mmproj]
        print(f"  🖼️  Detected mmproj: {os.path.basename(mmproj)}")

    # Env
    env = os.environ.copy()
    env['HSA_OVERRIDE_GFX_VERSION'] = '10.3.0'
    lib_dir = os.path.join(SCRIPT_DIR, "llama-b9656")
    env['LD_LIBRARY_PATH'] = (
        f'{lib_dir}:/opt/rocm-7.2.4/lib:'
        + env.get('LD_LIBRARY_PATH', '')
    )

    model_name = (
        os.path.basename(os.path.dirname(model_path))
        + "/" + os.path.basename(model_path)
    )

    print(f"\n  ╔══ ★ Server Starting ★ ════════════════╗")
    print(f"  ║  Model : {model_name:<35} ║")
    print(f"  ║  Config: {cfg_name:<35} ║")
    print(f"  ║  GPU   : RX 6800 XT (16GB ROCm)      ║")
    print(f"  ║  ngl   : {scfg['ngl']:<3} | ctx: {scfg['ctx']:<6}             ║")
    print(f"  ║  temp  : {scfg['temp']:<5} | port: {scfg['port']:<4}            ║")
    print(f"  ╚════════════════════════════════════════╝")
    print(f"\n  🌐 http://{scfg['host']}:{scfg['port']}/v1/chat/completions")
    print(f"  📡 http://{scfg['host']}:{scfg['port']}/metrics")
    print(f"\n  Press Ctrl+C to stop server\n")

    sys.stdout.flush()

    try:
        proc = subprocess.Popen(
            args,
            env=env,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
        )

        server_ready = False
        for line in proc.stdout:
            print(f"  {line}", end='')
            sys.stdout.flush()
            # Detect when server is actually listening
            if not server_ready and 'HTTP server listening' in line:
                server_ready = True
                print_ready_banner(scfg['host'], scfg['port'])

        proc.wait()
    except KeyboardInterrupt:
        print("\n\n  ⏹️  Server stopped~! ★")
        proc.terminate()
        try:
            proc.wait(timeout=5)
        except:
            proc.kill()

# ─── Main ───────────────────────────────────────────────
def main():
    while True:
        models = find_models()

        if not models:
            print_header()
            print("  ❌  No GGUF models found in:\n")
            print(f"     {SCRIPT_DIR}")
            print("\n  Taruh model .gguf di folder ini, lalu jalankan ulang~!\n")
            sys.exit(1)

        print_header()
        show_menu(models)
        choice = get_choice(len(models) + 1)

        if choice == len(models) + 1:
            print("\n  ★ Sampai jumpa~! ヽ(>∀<☆)ノ\n")
            sys.exit(0)

        model_path, model_rel, _ = models[choice - 1]
        cfg, cfg_name = load_model_config(model_rel)
        launch_server(cfg, model_path, cfg_name)

        # After server stops, prompt to go back to menu
        print("\n  🔄 Back to model list? (y/n): ", end='')
        try:
            again = input().strip().lower()
            if again not in ('y', 'yes', ''):
                break
        except (EOFError, KeyboardInterrupt):
            break

    print("\n  ★ Sampai jumpa~! ヽ(>∀<☆)ノ\n")


if __name__ == '__main__':
    main()
